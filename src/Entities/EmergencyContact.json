{
  "name": "EmergencyContact",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Contact name"
    },
    "phone": {
      "type": "string",
      "description": "Phone number"
    },
    "relationship": {
      "type": "string",
      "description": "Relationship to user"
    },
    "is_primary": {
      "type": "boolean",
      "default": false,
      "description": "Whether this is the primary emergency contact"
    },
    "notify_on_sos": {
      "type": "boolean",
      "default": true,
      "description": "Whether to notify this contact during SOS"
    }
  },
  "required": [
    "name",
    "phone"
  ]
}